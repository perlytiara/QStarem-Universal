{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QStarem",
  "version": "1.0.5",
  "identifier": "com.qstarem.universal",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "bash scripts/fetch-assets.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "QStarem",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "hiddenTitle": false,
        "titleBarStyle": "Overlay",
        "url": "https://zstream.mov",
        "backgroundColor": "#0A0A0F"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "shortDescription": "Z-Stream desktop browser shell",
    "longDescription": "Open-source desktop browser shell for Z-Stream with bundled P-Stream userscript injection.",
    "resources": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/variants/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxRUZDQUQ1QTc1N0U4QTAKUldTZzZGZW4xY3J2Z1dMYmtxSlRJa09MUVBjQ2dsVWxDeEVIamhmcG0rL3NsQ05NdXRzMUVSbWMK",
      "endpoints": [
        "https://github.com/perlytiara/QStarem-Universal/releases/latest/download/latest.json"
      ]
    }
  }
}
